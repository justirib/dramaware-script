local NOTIF_ICONS = {info="ℹ", success="✓", warning="⚠", error="✕"}
local NOTIF_COLORS = {
    info    = function() return T.Info end,
    success = function() return T.Success end,
    warning = function() return T.Warning end,
    error   = function() return T.Error end,
}

function x11:Notify(data)
    task.spawn(function()
        local title    = data.Title or "Notification"
        local content  = data.Content or ""
        local duration = data.Duration or 5
        local ntype    = data.Type or "info"
        local actions  = data.Actions or {}

        local accentCol = (NOTIF_COLORS[ntype] or NOTIF_COLORS.info)()

        -- Card
        local card = make("Frame",{
            Size=UDim2.new(1,0,0,0), BackgroundColor3=T.NotifBG,
            ClipsDescendants=true,
        }, NotifContainer)
        corner(card,8); stroke(card,T.NotifStroke,1)

        -- Left accent bar
        make("Frame",{
            Size=UDim2.new(0,3,1,0), BackgroundColor3=accentCol,
        }, card)
        corner(make("Frame",{Size=UDim2.new(0,3,1,0),BackgroundColor3=accentCol},card),8)

        local inner = make("Frame",{
            Size=UDim2.new(1,-10,0,0), Position=UDim2.new(0,8,0,0),
            AutomaticSize=Enum.AutomaticSize.Y, BackgroundTransparency=1,
        }, card)
        padding(inner,10,10,6,6)
        listLayout(inner, Enum.FillDirection.Vertical, 4)

        -- Icon + title row
        local headerRow = make("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1}, inner)
        label({
            Size=UDim2.new(0,18,1,0), Text=NOTIF_ICONS[ntype] or "•",
            TextColor3=accentCol, TextSize=14, Font=Enum.Font.GothamBold,
        }, headerRow)
        label({
            Size=UDim2.new(1,-22,1,0), Position=UDim2.new(0,22,0,0),
            Text=title, TextColor3=T.Text, TextSize=13, Font=Enum.Font.GothamBold,
        }, headerRow)

        -- Content
        label({
            Size=UDim2.new(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y,
            Text=content, TextColor3=T.SubText, TextSize=12,
            TextWrapped=true, Font=Enum.Font.Gotham,
        }, inner)

        -- Progress bar
        local progBG = make("Frame",{Size=UDim2.new(1,0,0,2),BackgroundColor3=T.Divider}, inner)
        corner(progBG,1)
        local progFill = make("Frame",{Size=UDim2.new(1,0,1,0),BackgroundColor3=accentCol}, progBG)
        corner(progFill,1)

        -- Action buttons
        if #actions > 0 then
            local actRow = make("Frame",{Size=UDim2.new(1,0,0,24),BackgroundTransparency=1}, inner)
            listLayout(actRow, Enum.FillDirection.Horizontal, 8)
            for _, act in ipairs(actions) do
                local ab = btn({
                    Size=UDim2.new(0,0,1,0), AutomaticSize=Enum.AutomaticSize.X,
                    Text=act.Name or "Action", TextColor3=accentCol, TextSize=12,
                    Font=Enum.Font.GothamBold, BackgroundTransparency=1,
                }, actRow)
                padding(ab,0,0,4,4)
                ab.MouseButton1Click:Connect(function()
                    if act.Callback then pcall(act.Callback) end
                end)
            end
        end

        -- Dismiss
        local dismissRow = make("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1}, inner)
        local dismissBtn = btn({
            Size=UDim2.new(0,55,1,0), Text="Dismiss",
            TextColor3=T.SubText, TextSize=11, Font=Enum.Font.Gotham,
        }, dismissRow)

        -- Calc height and animate in
        task.wait(0.02)
        local h = inner.AbsoluteSize.Y + 20
        h = math.max(h, 70)
        tw(card, 0.4, {Size=UDim2.new(1,0,0,h)})

        -- Countdown timer on progress bar
        local elapsed = 0
        local conn
        conn = RunService.Heartbeat:Connect(function(dt)
            elapsed = elapsed + dt
            local pct = 1 - clamp(elapsed/duration,0,1)
            progFill.Size = UDim2.new(pct,0,1,0)
            if elapsed >= duration then conn:Disconnect() end
        end)

        local function dismiss()
            conn:Disconnect()
            tw(card, 0.3, {BackgroundTransparency=1, Size=UDim2.new(1,0,0,0)})
            task.wait(0.35); card:Destroy()
        end
        dismissBtn.MouseButton1Click:Connect(dismiss)
        task.delay(duration, function() if card.Parent then dismiss() end end)
    end)
end

