-- GLOBAL API
-- ═══════════════════════════════════════════════════════════════
function x11:GetThemeNames()
    local names={}; for k in pairs(Themes) do table.insert(names,k) end
    table.sort(names); return names
end

function x11:AddCustomTheme(name, themeTable)
    local full={}
    for k,v in pairs(Themes.Default) do full[k]=v end
    for k,v in pairs(themeTable) do full[k]=v end
    Themes[name]=full
end

function x11:GetFlag(flag)
    return x11.Flags[flag]
end

function x11:Destroy()
    Root:Destroy()
end

return x11
