                rib.MouseButton1Click:Connect(function()
                    selected[opt]=not selected[opt]
                    box2.BackgroundColor3=selected[opt] and T.CheckboxOn or T.InputBG
                    chk.Text=selected[opt] and "✓" or ""
                    local keys={}; for k,v2 in pairs(selected) do if v2 then table.insert(keys,k) end end
                    el.CurrentOptions=keys
                    task.spawn(pcall,cb,keys)
                    if configEnabled then task.spawn(function() configObj:Save() end) end
                end)
            end
            el.Set=function(self2,v)
                selected={}
                if type(v)=="table" then for _,x in ipairs(v) do selected[x]=true end end
                for opt,cd in pairs(checks) do
                    cd.box.BackgroundColor3=selected[opt] and T.CheckboxOn or T.InputBG
                    cd.chk.Text=selected[opt] and "✓" or ""
                end
            end
            regElem(f,nm); return el
        end

        -- ── ACCORDION ─────────────────────────────────────────
        function Tab:CreateAccordion(data2)
            local title2= data2.Title or "Accordion"
            local startOpen = data2.Open or false

            local wrapper=make("Frame",{
                Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
                BackgroundColor3=T.ElementBG,LayoutOrder=nextLO(),ClipsDescendants=true,
            },tabScroll); corner(wrapper,6); stroke(wrapper,T.ElementStroke,1)

            local header=make("Frame",{
                Size=UDim2.new(1,0,0,36),BackgroundTransparency=1,
            },wrapper)
            label({Size=UDim2.new(1,-40,1,0),Position=UDim2.new(0,14,0,0),
                Text=title2,TextColor3=T.Text,TextSize=13,Font=Enum.Font.GothamBold},header)
            local arrow=label({Size=UDim2.new(0,20,1,0),Position=UDim2.new(1,-24,0,0),
                Text="▾",TextColor3=T.SubText,TextSize=13,Font=Enum.Font.GothamBold,
                TextXAlignment=Enum.TextXAlignment.Center},header)

            local body=make("Frame",{
                Size=UDim2.new(1,0,0,0),Position=UDim2.new(0,0,0,36),
                BackgroundTransparency=1,AutomaticSize=Enum.AutomaticSize.Y,Visible=startOpen,
            },wrapper)
            padding(body,4,8,10,10); listLayout(body,Enum.FillDirection.Vertical,5)

            local open=startOpen
            local hib=btn({Size=UDim2.new(1,0,1,0),Text="",BackgroundTransparency=1},header)
            hib.MouseButton1Click:Connect(function()
                open=not open
                body.Visible=open
                tw(arrow,.2,{Rotation=open and 180 or 0})
                tw(header,.15,{BackgroundColor3=open and T.ElementBGHover or Color3.fromRGB(0,0,0)})
                task.wait(.05); tw(header,.15,{BackgroundColor3=Color3.fromRGB(0,0,0)})
                header.BackgroundTransparency=1
            end)

            -- The accordion body is itself a mini-tab that supports elements
            local subTab={}
            local subLO=0
            local function subNext() subLO=subLO+1; return subLO end

            -- Re-expose a subset of element creators inside accordion body
            for _, mname in ipairs({"CreateButton","CreateToggle","CreateSlider","CreateInput","CreateLabel","CreateSeparator"}) do
                subTab[mname] = function(self2, d2)
                    -- Temporarily redirect tabScroll to body
                    local origScroll=tabScroll
                    -- We use a wrapper trick: create element with LayoutOrder
                    local origLO=lo
                    -- Directly parent to body
                    local saved=tabScroll
                    tabScroll=body
                    lo=subLO
                    Tab[mname](Tab,d2)
                    subLO=lo; lo=origLO
                    tabScroll=saved
                end
            end

            regElem(wrapper,title2)
            return subTab
        end

        -- ── BADGE ─────────────────────────────────────────────
        function Tab:CreateBadge(data2)
            local items = data2.Items or {}  -- {Text, Color, Icon}
            local nm2   = data2.Name or "Badges"

            local f=make("Frame",{
                Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
                BackgroundTransparency=1,LayoutOrder=nextLO(),
            },tabScroll)
            if nm2~="" then
                label({Size=UDim2.new(1,0,0,18),Text=nm2,TextColor3=T.SectionText,TextSize=10,
                    Font=Enum.Font.GothamBold},f)
            end
            local badgeRow=make("Frame",{
                Size=UDim2.new(1,0,0,26),Position=UDim2.new(0,0,0,nm2~="" and 20 or 0),
                BackgroundTransparency=1,
            },f)
            listLayout(badgeRow,Enum.FillDirection.Horizontal,6)
            for _,item in ipairs(items) do
                local bc=item.Color or T.Accent
                local bf=make("Frame",{
                    Size=UDim2.new(0,0,0,22),AutomaticSize=Enum.AutomaticSize.X,
                    BackgroundColor3=bc,
                },badgeRow); corner(bf,11)
                padding(bf,0,0,10,10)
                label({Size=UDim2.new(0,0,1,0),AutomaticSize=Enum.AutomaticSize.X,
                    Text=(item.Icon and item.Icon.." " or "")..item.Text,
                    TextColor3=Color3.fromRGB(255,255,255),TextSize=11,Font=Enum.Font.GothamBold,
                    TextXAlignment=Enum.TextXAlignment.Center},bf)
            end
            if nm2~="" then f.Size=UDim2.new(1,0,0,46) end
            regElem(f,nm2~="" and nm2 or "badges")
        end

        -- ── IMAGE ─────────────────────────────────────────────
        function Tab:CreateImage(data2)
            local imgId = data2.Image or ""
            local h2    = data2.Height or 80
            local nm2   = data2.Name or ""

            local f=make("Frame",{
                Size=UDim2.new(1,0,0,h2),BackgroundColor3=T.ElementBG,LayoutOrder=nextLO(),
            },tabScroll); corner(f,6); stroke(f,T.ElementStroke,1)
            make("ImageLabel",{
                Size=UDim2.new(1,-16,1,-16),Position=UDim2.new(0,8,0,8),
                BackgroundTransparency=1,Image=imgId,ScaleType=Enum.ScaleType.Fit,
            },f)
            if nm2~="" then
                label({Size=UDim2.new(1,-16,0,16),Position=UDim2.new(0,8,1,-20),
                    Text=nm2,TextColor3=T.SubText,TextSize=10},f)
            end
            regElem(f,nm2~="" and nm2 or "image")
        end

        return Tab
    end -- CreateTab

    -- Load config after window is built
    if configEnabled then
        task.delay(0.5, function() configObj:Load() end)
    end

    return Window
end -- CreateWindow

