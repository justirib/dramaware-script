        -- ── DROPDOWN ──────────────────────────────────────────
        function Tab:CreateDropdown(data2)
            local nm    = data2.Name or "Dropdown"
            local opts  = data2.Options or {}
            local multi = data2.MultipleOptions or false
            local cur   = data2.CurrentOption or {}
            local flag  = data2.Flag
            local cb    = data2.Callback or function() end
            local searchable = data2.Searchable or false

            local f=make("Frame",{
                Size=UDim2.new(1,0,0,38),BackgroundColor3=T.ElementBG,
                LayoutOrder=nextLO(),ClipsDescendants=false,
            },tabScroll); corner(f,6); stroke(f,T.ElementStroke,1)

            label({Size=UDim2.new(0,100,1,0),Position=UDim2.new(0,14,0,0),
                Text=nm,TextColor3=T.Text,TextSize=13,Font=Enum.Font.GothamBold},f)
            local selLbl=label({
                Size=UDim2.new(1,-130,1,0),Position=UDim2.new(0,112,0,0),
                Text=#cur>0 and table.concat(cur,", ") or "None",
                TextColor3=T.SubText,TextSize=12,TextTruncate=Enum.TextTruncate.AtEnd,
            },f)
            local arrow=label({Size=UDim2.new(0,20,1,0),Position=UDim2.new(1,-22,0,0),
                Text="▾",TextColor3=T.SubText,TextSize=13,Font=Enum.Font.GothamBold,
                TextXAlignment=Enum.TextXAlignment.Center},f)

            -- Modal
            local modal=make("Frame",{
                Size=UDim2.new(1,0,0,0),Position=UDim2.new(0,0,1,4),
                BackgroundColor3=T.DropdownBG,ClipsDescendants=true,ZIndex=20,Visible=false,
            },f); corner(modal,6); stroke(modal,T.ElementStroke,1)

            local modalScroll=make("ScrollingFrame",{
                Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
                ScrollBarThickness=2,ScrollBarImageColor3=T.ElementStroke,
                CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,ZIndex=20,
            },modal)
            padding(modalScroll,4,4,4,4); listLayout(modalScroll,Enum.FillDirection.Vertical,2)

            local sel={}
            for _,v in ipairs(cur) do sel[v]=true end

            local el={Type="Dropdown",CurrentOption=cur,_default=cur}
            if flag then x11.Flags[flag]=el end

            local ddOpen=false

            local function refreshDisp()
                local keys={}; for k in pairs(sel) do table.insert(keys,k) end
                el.CurrentOption=keys
                selLbl.Text=#keys>0 and table.concat(keys,", ") or "None"
            end

            local function buildModal(filter)
                for _,c in ipairs(modalScroll:GetChildren()) do
                    if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end
                end
                for _,opt in ipairs(opts) do
                    if not filter or opt:lower():find(filter:lower(),1,true) then
                        local isSel=sel[opt]==true
                        local ib2=btn({
                            Size=UDim2.new(1,0,0,28),BackgroundColor3=isSel and T.DropdownHover or T.DropdownItem,
                            BackgroundTransparency=0,Text="",ZIndex=21,
                        },modalScroll)
                        corner(ib2,4)
                        label({Size=UDim2.new(1,-28,1,0),Position=UDim2.new(0,10,0,0),
                            Text=opt,TextColor3=isSel and T.Text or T.SubText,
                            TextSize=12,Font=isSel and Enum.Font.GothamBold or Enum.Font.Gotham,ZIndex=21},ib2)
                        label({Size=UDim2.new(0,16,1,0),Position=UDim2.new(1,-18,0,0),
                            Text=isSel and "✓" or "",TextColor3=T.Accent,TextSize=11,
                            Font=Enum.Font.GothamBold,ZIndex=21,TextXAlignment=Enum.TextXAlignment.Center},ib2)
                        ib2.MouseButton1Click:Connect(function()
                            if multi then sel[opt]=not sel[opt]
                            else sel={}; sel[opt]=true end
                            refreshDisp(); buildModal(filter)
                            local keys={}; for k in pairs(sel) do table.insert(keys,k) end
                            task.spawn(pcall,cb,keys)
                            if not multi then
                                ddOpen=false
                                tw(modal,.15,{Size=UDim2.new(1,0,0,0)}); tw(arrow,.15,{Rotation=0})
                                task.wait(.15); modal.Visible=false
                            end
                            if configEnabled then task.spawn(function() configObj:Save() end) end
                        end)
                    end
                end
                -- Confirm/Cancel
                local actRow=make("Frame",{Size=UDim2.new(1,0,0,24),BackgroundTransparency=1,ZIndex=21},modalScroll)
