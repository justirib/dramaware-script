        -- ── TOGGLE ────────────────────────────────────────────
        function Tab:CreateToggle(data2)
            local nm  = data2.Name or "Toggle"
            local desc= data2.Description or ""
            local cur = data2.CurrentValue or false
            local flag= data2.Flag
            local cb  = data2.Callback or function() end
            local h   = desc~="" and 50 or 38
            local f,_ = elemFrame(h)

            label({Size=UDim2.new(1,-70,0,18),Position=UDim2.new(0,14,0,desc~="" and 8 or 10),
                Text=nm,TextColor3=T.Text,TextSize=13,Font=Enum.Font.GothamBold},f)
            if desc~="" then
                label({Size=UDim2.new(1,-70,0,14),Position=UDim2.new(0,14,0,28),
                    Text=desc,TextColor3=T.SubText,TextSize=11},f)
            end

            -- Switch
            local sw=make("Frame",{
                Size=UDim2.new(0,42,0,20),Position=UDim2.new(1,-52,0.5,-10),
                BackgroundColor3=cur and T.ToggleOn or T.ToggleOff,
            },f); corner(sw,10)
            local swStr=stroke(sw, cur and T.ToggleOn or T.ToggleOff, 1.5)
            local knob=make("Frame",{
                Size=UDim2.new(0,14,0,14),
                Position=cur and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7),
                BackgroundColor3=T.ToggleKnob,
            },sw); corner(knob,7)

            local el={Type="Toggle",CurrentValue=cur,_default=data2.CurrentValue}
            if flag then x11.Flags[flag]=el end

            local function setTog(v,fire)
                el.CurrentValue=v
                tw(sw,.2,{BackgroundColor3=v and T.ToggleOn or T.ToggleOff})
                tw(swStr,.2,{Color=v and T.ToggleOn or T.ToggleOff})
                tw(knob,.2,{Position=v and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7)})
                if fire then task.spawn(pcall,cb,v) end
                if configEnabled then task.spawn(function() configObj:Save() end) end
            end
            el.Set=function(self2,v) cur=v; setTog(v,false) end

            local ib=btn({Size=UDim2.new(1,0,1,0),Text="",BackgroundTransparency=1,ZIndex=3},f)
            ib.MouseButton1Click:Connect(function() cur=not cur; setTog(cur,true) end)
            regElem(f,nm); return el
        end

        -- ── SLIDER ────────────────────────────────────────────
        function Tab:CreateSlider(data2)
            local nm   = data2.Name or "Slider"
            local rng  = data2.Range or {0,100}
            local inc  = data2.Increment or 1
            local suf  = data2.Suffix or ""
            local cur  = clamp(data2.CurrentValue or rng[1], rng[1], rng[2])
            local flag = data2.Flag
            local cb   = data2.Callback or function() end
            local showInput = data2.ShowInput ~= false

            local f=make("Frame",{
                Size=UDim2.new(1,0,0,54),BackgroundColor3=T.ElementBG,LayoutOrder=nextLO(),
            },tabScroll); corner(f,6); stroke(f,T.ElementStroke,1)

            label({Size=UDim2.new(0.55,0,0,20),Position=UDim2.new(0,14,0,6),
                Text=nm,TextColor3=T.Text,TextSize=13,Font=Enum.Font.GothamBold},f)

            local valLbl=label({
                Size=UDim2.new(0.45,-10,0,20),Position=UDim2.new(0.55,0,0,6),
                Text=tostring(cur)..(suf~="" and " "..suf or ""),
                TextColor3=T.SubText,TextSize=12,TextXAlignment=Enum.TextXAlignment.Right,
            },f)

            local trackBG=make("Frame",{
                Size=UDim2.new(1,-28,0,5),Position=UDim2.new(0,14,0,36),
                BackgroundColor3=T.SliderBG,
            },f); corner(trackBG,3)

            local pct=(cur-rng[1])/(rng[2]-rng[1])
            local fill=make("Frame",{Size=UDim2.new(pct,0,1,0),BackgroundColor3=T.SliderFill},trackBG)
            corner(fill,3)
            local knob2=make("Frame",{
                Size=UDim2.new(0,11,0,11),AnchorPoint=Vector2.new(0.5,0.5),
                Position=UDim2.new(pct,0,0.5,0),BackgroundColor3=T.SliderKnob,ZIndex=3,
            },trackBG); corner(knob2,6)

            local el={Type="Slider",CurrentValue=cur,_default=data2.CurrentValue}
            if flag then x11.Flags[flag]=el end

            local function updateSlider(v,fire)
                v=round(clamp(v,rng[1],rng[2])/inc)*inc
                v=clamp(v,rng[1],rng[2])
                el.CurrentValue=v
                local p=(v-rng[1])/(rng[2]-rng[1])
                fill.Size=UDim2.new(p,0,1,0)
                knob2.Position=UDim2.new(p,0,0.5,0)
                valLbl.Text=tostring(v)..(suf~="" and " "..suf or "")
                if fire then task.spawn(pcall,cb,v) end
                if configEnabled then task.spawn(function() configObj:Save() end) end
            end
            el.Set=function(self2,v) updateSlider(v,false) end

            local sliding=false
            local si=btn({Size=UDim2.new(1,0,1,14),Position=UDim2.new(0,0,0,-7),
                Text="",BackgroundTransparency=1,ZIndex=5},trackBG)
            si.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1
                or i.UserInputType==Enum.UserInputType.Touch then sliding=true end
            end)
            UIS.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1
                or i.UserInputType==Enum.UserInputType.Touch then sliding=false end
            end)
            UIS.InputChanged:Connect(function(i)
                if sliding and (i.UserInputType==Enum.UserInputType.MouseMovement
                or i.UserInputType==Enum.UserInputType.Touch) then
                    local ap=trackBG.AbsolutePosition.X
                    local as=trackBG.AbsoluteSize.X
                    local rx=clamp(i.Position.X-ap,0,as)
                    updateSlider(rng[1]+(rng[2]-rng[1])*(rx/as),true)
                end
            end)

            regElem(f,nm); return el
        end

