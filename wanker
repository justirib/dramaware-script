                Color3.fromRGB(80,220,80), Color3.fromRGB(80,160,255),
                Color3.fromRGB(180,80,255), Color3.fromRGB(255,80,200),
                Color3.fromRGB(255,255,255), Color3.fromRGB(0,0,0),
            }
            local function addSwatch(sc)
                local sb=make("Frame",{Size=UDim2.new(0,18,0,18),BackgroundColor3=sc},swatchRow)
                corner(sb,4)
                local sib=btn({Size=UDim2.new(1,0,1,0),Text="",BackgroundTransparency=1},sb)
                sib.MouseButton1Click:Connect(function()
                    col=sc; h2,s2,v2=Color3.toHSV(sc); updateCP(false)
                end)
            end
            for _,sc in ipairs(defaultSwatches) do addSwatch(sc) end

            -- SV Canvas
            local canvas=make("ImageLabel",{
                Size=UDim2.new(1,0,0,110),BackgroundColor3=Color3.fromRGB(255,0,0),
                Image="rbxassetid://4155801252",ScaleType=Enum.ScaleType.Stretch,
            },ip); corner(canvas,5); stroke(canvas,T.ElementStroke,1)
            local cpk=make("Frame",{
                Size=UDim2.new(0,10,0,10),AnchorPoint=Vector2.new(.5,.5),
                Position=UDim2.new(1,0,0,0),BackgroundColor3=Color3.fromRGB(255,255,255),ZIndex=5,
            },canvas); corner(cpk,5); stroke(cpk,Color3.fromRGB(0,0,0),1.5)

            -- Hue bar
            local hBar=make("ImageLabel",{
                Size=UDim2.new(1,0,0,12),Image="rbxassetid://4155805523",ScaleType=Enum.ScaleType.Stretch,
            },ip); corner(hBar,4); stroke(hBar,T.ElementStroke,1)
            local hk=make("Frame",{
                Size=UDim2.new(0,8,1,4),AnchorPoint=Vector2.new(.5,.5),Position=UDim2.new(0,0,.5,0),
                BackgroundColor3=Color3.fromRGB(255,255,255),ZIndex=5,
            },hBar); corner(hk,3); stroke(hk,Color3.fromRGB(0,0,0),1)

            -- Alpha bar
            local aBar=make("ImageLabel",{
                Size=UDim2.new(1,0,0,12),Image="rbxassetid://698052001",ScaleType=Enum.ScaleType.Stretch,
            },ip); corner(aBar,4); stroke(aBar,T.ElementStroke,1)
            local ak=make("Frame",{
                Size=UDim2.new(0,8,1,4),AnchorPoint=Vector2.new(.5,.5),Position=UDim2.new(1,0,.5,0),
                BackgroundColor3=Color3.fromRGB(255,255,255),ZIndex=5,
            },aBar); corner(ak,3); stroke(ak,Color3.fromRGB(0,0,0),1)

            -- RGB + Hex row
            local rgbRow=make("Frame",{Size=UDim2.new(1,0,0,24),BackgroundTransparency=1},ip)
            listLayout(rgbRow,Enum.FillDirection.Horizontal,4)
            local function makeRGBBox(ph2)
                local b=make("TextBox",{
                    Size=UDim2.new(0,44,1,0),BackgroundColor3=T.InputBG,
                    TextColor3=T.Text,TextSize=11,Font=Enum.Font.GothamBold,
                    PlaceholderText=ph2,PlaceholderColor3=T.Placeholder,
                    ClearTextOnFocus=false,Text="",
                },rgbRow); corner(b,4); stroke(b,T.InputStroke,1); padding(b,0,0,5,5)
                return b
            end
            local rBox=makeRGBBox("R"); local gBox=makeRGBBox("G"); local bBox=makeRGBBox("B")
            label({Size=UDim2.new(0,30,1,0),Text="RGB",TextColor3=T.SubText,TextSize=10,
                Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Center},rgbRow)
            local hexBox=make("TextBox",{
                Size=UDim2.new(1,-140,1,0),BackgroundColor3=T.InputBG,
                TextColor3=T.Text,TextSize=11,Font=Enum.Font.GothamBold,
                PlaceholderText="#FFFFFF",PlaceholderColor3=T.Placeholder,
                ClearTextOnFocus=false,Text="",
            },rgbRow); corner(hexBox,4); stroke(hexBox,T.InputStroke,1); padding(hexBox,0,0,5,5)

            -- Action row
            local actRow=make("Frame",{Size=UDim2.new(1,0,0,20),BackgroundTransparency=1},ip)
            listLayout(actRow,Enum.FillDirection.Horizontal,8)
            local cfmBtn=btn({Size=UDim2.new(0,58,1,0),Text="Confirm",TextColor3=T.Accent,TextSize=11,Font=Enum.Font.GothamBold},actRow)
            local cncBtn=btn({Size=UDim2.new(0,50,1,0),Text="Cancel",TextColor3=T.SubText,TextSize=11},actRow)
            local saveSwBtn=btn({Size=UDim2.new(0,80,1,0),Text="+ Swatch",TextColor3=T.SubText,TextSize=11},actRow)

            local el={Type="ColorPicker",Color=col,Alpha=1,_default=col}
            if flag then x11.Flags[flag]=el end

            local h2,s2,v2=Color3.toHSV(col)
            local alpha2=1
            local saved=col

            local function colorToHex(c)
                return string.format("#%02X%02X%02X",
                    math.floor(c.R*255),math.floor(c.G*255),math.floor(c.B*255))
            end

            local function updateCP(fire)
                local c=Color3.fromHSV(h2,s2,v2)
                col=c; el.Color=c; el.Alpha=alpha2
                prev.BackgroundColor3=c
                canvas.BackgroundColor3=Color3.fromHSV(h2,1,1)
                cpk.Position=UDim2.new(s2,-5,1-v2,-5)
                hk.Position=UDim2.new(h2,0,.5,0)
                ak.Position=UDim2.new(alpha2,0,.5,0)
                rBox.Text=tostring(math.floor(c.R*255))
                gBox.Text=tostring(math.floor(c.G*255))
                bBox.Text=tostring(math.floor(c.B*255))
                hexBox.Text=colorToHex(c)
                if fire then task.spawn(pcall,cb,c,alpha2) end
            end

            el.Set=function(self2,c)
                h2,s2,v2=Color3.toHSV(c); alpha2=1; updateCP(false)
            end

            -- Canvas drag
            local dragCanvas,dragHue,dragAlpha=false,false,false
            local function makeDragTarget(obj, fn)
                obj.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1
                    or i.UserInputType==Enum.UserInputType.Touch then fn(true) end
                end)
            end
            makeDragTarget(canvas,function() dragCanvas=true end)
            makeDragTarget(hBar,function() dragHue=true end)
            makeDragTarget(aBar,function() dragAlpha=true end)
            UIS.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1
                or i.UserInputType==Enum.UserInputType.Touch then
                    dragCanvas=false; dragHue=false; dragAlpha=false
                end
            end)
            UIS.InputChanged:Connect(function(i)
                if i.UserInputType~=Enum.UserInputType.MouseMovement
                and i.UserInputType~=Enum.UserInputType.Touch then return end
                if dragCanvas then
                    local ap=canvas.AbsolutePosition; local as=canvas.AbsoluteSize
                    s2=clamp((i.Position.X-ap.X)/as.X,0,1)
                    v2=1-clamp((i.Position.Y-ap.Y)/as.Y,0,1)
                    updateCP(true)
                elseif dragHue then
                    local ap=hBar.AbsolutePosition; local as=hBar.AbsoluteSize
                    h2=clamp((i.Position.X-ap.X)/as.X,0,1); updateCP(true)
                elseif dragAlpha then
                    local ap=aBar.AbsolutePosition; local as=aBar.AbsoluteSize
                    alpha2=clamp((i.Position.X-ap.X)/as.X,0,1); updateCP(true)
                end
            end)
            -- RGB box input
            local function applyRGB()
                local r2=tonumber(rBox.Text); local g2=tonumber(gBox.Text); local b2=tonumber(bBox.Text)
                if r2 and g2 and b2 then
                    local c=Color3.fromRGB(clamp(r2,0,255),clamp(g2,0,255),clamp(b2,0,255))
                    h2,s2,v2=Color3.toHSV(c); updateCP(true)
                end
            end
            rBox.FocusLost:Connect(applyRGB); gBox.FocusLost:Connect(applyRGB); bBox.FocusLost:Connect(applyRGB)
            hexBox.FocusLost:Connect(function()
                local hex=hexBox.Text:gsub("#","")
                if #hex==6 then
                    local r2=tonumber(hex:sub(1,2),16); local g2=tonumber(hex:sub(3,4),16); local b2=tonumber(hex:sub(5,6),16)
                    if r2 and g2 and b2 then
                        local c=Color3.fromRGB(r2,g2,b2); h2,s2,v2=Color3.toHSV(c); updateCP(true)
                    end
                end
            end)
            cfmBtn.MouseButton1Click:Connect(function() saved=col; task.spawn(pcall,cb,col,alpha2) end)
            cncBtn.MouseButton1Click:Connect(function() h2,s2,v2=Color3.toHSV(saved); alpha2=1; updateCP(false) end)
            saveSwBtn.MouseButton1Click:Connect(function() addSwatch(col) end)

            updateCP(false)
            regElem(outer,nm); return el
        end

