            local f = make("Frame",{
                Size=UDim2.new(1,0,0,h or 38),
                BackgroundColor3=T.ElementBG,
                LayoutOrder=nextLO(),
            }, tabScroll)
            corner(f,6); stroke(f,T.ElementStroke,1)
            -- Hover
            local inter = btn({Size=UDim2.new(1,0,1,0),Text="",BackgroundTransparency=1,ZIndex=2},f)
            inter.MouseEnter:Connect(function() tw(f,.12,{BackgroundColor3=T.ElementBGHover}) end)
            inter.MouseLeave:Connect(function() tw(f,.12,{BackgroundColor3=T.ElementBG}) end)
            return f, inter
        end

        local Tab = {}

