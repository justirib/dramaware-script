    function configObj:Save()
        if not configEnabled then return end
        local data = {}
        for flag, elem in pairs(x11.Flags) do
            if not elem._noSave then
                if elem.Type=="Toggle"      then data[flag]=elem.CurrentValue
                elseif elem.Type=="Slider"  then data[flag]=elem.CurrentValue
                elseif elem.Type=="Input"   then data[flag]=elem.CurrentValue
                elseif elem.Type=="Dropdown"then data[flag]=elem.CurrentOption
                elseif elem.Type=="ColorPicker" then
                    data[flag]={R=elem.Color.R*255,G=elem.Color.G*255,B=elem.Color.B*255}
                elseif elem.Type=="Keybind" then data[flag]=elem.CurrentKeybind
                elseif elem.Type=="Stepper" then data[flag]=elem.CurrentValue
                elseif elem.Type=="RadioGroup" then data[flag]=elem.CurrentOption
                end
            end
        end
        safeWrite(self._file, jsonEncode(data) or "{}")
    end

    function configObj:Load()
        if not configEnabled then return end
        local raw = safeRead(self._file)
        if not raw then return end
        local data = jsonDecode(raw)
        if not data then return end
        for flag, val in pairs(data) do
            local elem = x11.Flags[flag]
            if elem and elem.Set then
                pcall(function()
                    if elem.Type=="ColorPicker" and type(val)=="table" then
                        elem:Set(Color3.fromRGB(val.R or 255, val.G or 255, val.B or 255))
                    elseif elem.Type=="Dropdown" and type(val)=="table" then
                        elem:Set(val)
                    else
                        elem:Set(val)
                    end
                end)
            end
        end
    end

    function configObj:Reset()
        for flag, elem in pairs(x11.Flags) do
            if elem._default ~= nil and elem.Set then
                pcall(elem.Set, elem, elem._default)
            end
        end
    end

    function configObj:SaveProfile(name)
        if not configEnabled then return end
        local path = configFolder.."/Profiles/"..name..".json"
        local data = {}
        for flag, elem in pairs(x11.Flags) do
            if elem.Type=="Toggle"       then data[flag]=elem.CurrentValue
            elseif elem.Type=="Slider"   then data[flag]=elem.CurrentValue
            elseif elem.Type=="Dropdown" then data[flag]=elem.CurrentOption end
        end
        safeWrite(path, jsonEncode(data) or "{}")
    end

    function configObj:LoadProfile(name)
        if not configEnabled then return end
        local path = configFolder.."/Profiles/"..name..".json"
        local raw = safeRead(path)
        if not raw then return end
        local data = jsonDecode(raw)
        if not data then return end
        for flag, val in pairs(data) do
            local elem = x11.Flags[flag]
            if elem and elem.Set then pcall(elem.Set, elem, val) end
        end
    end

    function configObj:ExportString()
        local data = {}
        for flag, elem in pairs(x11.Flags) do
            if elem.Type=="Toggle" then data[flag]=elem.CurrentValue
            elseif elem.Type=="Slider" then data[flag]=elem.CurrentValue end
        end
        return jsonEncode(data) or "{}"
    end

    function configObj:ImportString(str)
        local data = jsonDecode(str)
        if not data then return false end
        for flag, val in pairs(data) do
            local elem = x11.Flags[flag]
            if elem and elem.Set then pcall(elem.Set, elem, val) end
        end
        return true
    end

    -- ── TAB SYSTEM ────────────────────────────────────────────
    local Window = {}
    Window._tabs      = {}
    Window._tabBtns   = {}
    Window._active    = nil
    Window.Config     = configObj

    function Window:SetTheme(name)
        applyTheme(name)
        -- Re-color live elements would require a full redraw; for now
        -- notify and suggest re-exec (common pattern in Roblox UI libs)
        x11:Notify({Title="Theme",Content="Theme '"..tostring(name).."' applied. Re-run script to see full change.",Type="info",Duration=4})
    end

    function Window:_switch(name)
        for n, td in pairs(self._tabs) do
            td._scroll.Visible = (n==name)
        end
        for n, b in pairs(self._tabBtns) do
            local sel = (n==name)
            tw(b, 0.18, {
                BackgroundColor3=sel and T.TabSelected or T.TabUnselected,
                BackgroundTransparency=sel and 0 or 0.72,
            })
            b.Title.TextColor3 = sel and T.TabSelectedText or T.TabUnselectedText
            b.Title.Font = sel and Enum.Font.GothamBold or Enum.Font.Gotham
        end
        self._active = name
    end

    -- Search
    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        local q = searchBox.Text:lower():gsub("^%s+",""):gsub("%s+$","")
        for _, ed in ipairs(x11._allElements) do
            if ed._frame and ed._frame.Parent then
                local match = q=="" or (ed._name and ed._name:lower():find(q,1,true))
                ed._frame.Visible = match ~= nil
            end
        end
    end)

    -- ── CREATE TAB ────────────────────────────────────────────
    function Window:CreateTab(name, _icon, badge)
        -- Sidebar button
        local tabBtn = make("Frame",{
            Name=name, Size=UDim2.new(1,0,0,28),
            BackgroundColor3=T.TabUnselected, BackgroundTransparency=0.72,
        }, SideScroll)
        corner(tabBtn,6)
        local tabTitle = label({
            Name="Title", Size=UDim2.new(1,-10,1,0), Position=UDim2.new(0,10,0,0),
            Text=name, TextColor3=T.TabUnselectedText, TextSize=12, Font=Enum.Font.Gotham,
        }, tabBtn)
        -- Badge
        if badge then
            local badgeFrame = make("Frame",{
                Size=UDim2.new(0,18,0,14),Position=UDim2.new(1,-22,0.5,-7),
                BackgroundColor3=T.Error,
            }, tabBtn)
            corner(badgeFrame,7)
            label({Size=UDim2.new(1,0,1,0),Text=tostring(badge),
                TextColor3=Color3.fromRGB(255,255,255),TextSize=9,Font=Enum.Font.GothamBold,
                TextXAlignment=Enum.TextXAlignment.Center}, badgeFrame)
        end

        local tabInteract = btn({Size=UDim2.new(1,0,1,0),Text="",BackgroundTransparency=1},tabBtn)

        -- Scroll for content
        local tabScroll = make("ScrollingFrame",{
            Name=name.."_scroll",Size=UDim2.new(1,0,1,0),
            BackgroundTransparency=1, ScrollBarThickness=2,
            ScrollBarImageColor3=T.ElementStroke, Visible=false,
            CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,
        }, Content)
        padding(tabScroll,8,8,8,8)
        listLayout(tabScroll, Enum.FillDirection.Vertical, 6)

        self._tabs[name]   = {_scroll=tabScroll, _elements={}}
        self._tabBtns[name]= tabBtn

        tabInteract.MouseButton1Click:Connect(function() self:_switch(name) end)
        tabInteract.MouseEnter:Connect(function()
            if self._active~=name then tw(tabBtn,.12,{BackgroundTransparency=0.55}) end
        end)
        tabInteract.MouseLeave:Connect(function()
            if self._active~=name then tw(tabBtn,.12,{BackgroundTransparency=0.72}) end
        end)

        if not self._active then self:_switch(name) end

        -- ── ELEMENT REGISTRY ──────────────────────────────────
        local tabData = self._tabs[name]
        local lo = 0
        local function nextLO() lo=lo+1; return lo end
        local function regElem(frame, nm)
            local ed = {_frame=frame,_name=nm}
            table.insert(tabData._elements, ed)
            table.insert(x11._allElements, ed)
            return ed
        end

